# Spotify API — Create an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_client_id
SPOTIFY_CLIENT_SECRET=your_client_secret
SPOTIFY_REDIRECT_URI=http://localhost:8888/callback
SPOTIFY_REFRESH_TOKEN=

# Bandsintown API — Get a key at https://www.bandsintown.com/api
BANDSINTOWN_API_KEY=your_bandsintown_api_key

# Email (Gmail example — use an App Password, not your real password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_TO=your_email@gmail.com

# Optional: override the number of top matches in the email digest
EMAIL_TOP_N=10
