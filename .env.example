# Spotify API — Create an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_client_id
SPOTIFY_CLIENT_SECRET=your_client_secret
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback
SPOTIFY_REFRESH_TOKEN=

# Bandsintown API — Get a key at https://www.bandsintown.com/api (optional fallback)
BANDSINTOWN_API_KEY=

# Resend — Get a free API key at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_TO=you@example.com

# Optional: override the number of top matches in the email digest
EMAIL_TOP_N=10
